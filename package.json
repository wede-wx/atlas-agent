{
  "name": "aura",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "smoke": "node scripts/smoke-aura.mjs",
    "smoke:desktop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-smoke-aura.ps1",
    "probe:island-wgc": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-wgc.ps1",
    "probe:island-wgc-rust": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-wgc-rust.ps1",
    "probe:island-ocr": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-ocr-matrix.ps1",
    "probe:island-ocr-real": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-ocr-real-windows.ps1",
    "probe:island-capture-occlusion": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-capture-occlusion.ps1",
    "probe:island-capture-minimized": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-capture-minimized.ps1",
    "probe:island-capture-protected": "powershell -NoProfile -STA -ExecutionPolicy Bypass -File ./scripts/probe-island-capture-protected.ps1",
    "probe:island-media": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-media.ps1",
    "probe:island-real-media": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-real-media-session.ps1",
    "probe:island-external-readiness": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-external-readiness.ps1",
    "probe:island-external-matrix": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/run-island-external-matrix.ps1",
    "probe:island-stability": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-stability.ps1",
    "probe:island-host": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-host-matrix.ps1",
    "probe:island-focus": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-smoke-aura.ps1 -WaitSeconds 180 -SkipReturnToMain -ExerciseIslandExternalFocus -ExerciseIslandInputAvoidance",
    "probe:island-snap": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-smoke-aura.ps1 -WaitSeconds 180 -SkipReturnToMain -ExerciseIslandSnap",
    "probe:island-multiapp-focus": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-smoke-aura.ps1 -WaitSeconds 180 -SkipReturnToMain -ExerciseIslandMultiAppFocus",
