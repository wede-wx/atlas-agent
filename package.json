    "probe:island-overlay-cancel": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-smoke-aura.ps1 -WaitSeconds 180 -SkipGlobalShortcut -AllowGlobalShortcutConflict -SkipReturnToMain -ExerciseIslandOverlayCancel",
    "probe:island-overlay-toolbar-cancel": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-smoke-aura.ps1 -WaitSeconds 180 -SkipGlobalShortcut -AllowGlobalShortcutConflict -SkipReturnToMain -ExerciseIslandOverlayToolbarCancel",
    "probe:island-overlay-actions": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-smoke-aura.ps1 -WaitSeconds 180 -SkipGlobalShortcut -AllowGlobalShortcutConflict -SkipReturnToMain -ExerciseIslandOverlayActions",
    "probe:island-overlay-toolbar-actions": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-smoke-aura.ps1 -WaitSeconds 180 -SkipGlobalShortcut -AllowGlobalShortcutConflict -SkipReturnToMain -ExerciseIslandOverlayToolbarActions",
    "probe:island-overlay-keyboard-adjust": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-smoke-aura.ps1 -WaitSeconds 180 -SkipGlobalShortcut -AllowGlobalShortcutConflict -SkipReturnToMain -ExerciseIslandOverlayKeyboardAdjust",
    "probe:island-overlay-color": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/desktop-smoke-aura.ps1 -WaitSeconds 180 -SkipGlobalShortcut -AllowGlobalShortcutConflict -SkipReturnToMain -ExerciseIslandOverlayColor",
    "probe:island-window-context": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/probe-island-window-context-matrix.ps1",
    "audit:island-completion": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/audit-island-completion-gate.ps1",
    "new:island-external-evidence-note": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/new-island-external-evidence-note.ps1",
    "new:island-manual-evidence": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/new-island-manual-external-evidence.ps1",
    "record:island-external-evidence": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/record-island-external-evidence.ps1",
    "verify": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-aura.ps1",
    "verify:feishu-receive": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-feishu-receive.ps1",
    "feishu:callback-host": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-feishu-callback-host.ps1",
    "feishu:callback-status": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-feishu-callback-host.ps1 -StatusOnly",
    "feishu:websocket-receiver": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/start-feishu-websocket-receiver.ps1",
    "feishu:stop": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/stop-feishu-receiver.ps1",
    "feishu:diagnose": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/diagnose-feishu-app.ps1",
    "feishu:open-setup": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/open-feishu-setup.ps1",
    "feishu:finalize": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/finalize-feishu-receive.ps1",
    "feishu:wait-receive": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/wait-feishu-receive.ps1",
    "test": "npm run verify",
    "test:harness": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/verify-aura.ps1 -HarnessOnly -SkipFrontend",
    "test:research": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/research-e2e.ps1",
    "tauri": "tauri"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@larksuiteoapi/node-sdk": "^1.65.0",
    "@tauri-apps/api": "2.10.1",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.4",
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "playwright": "^1.59.1",
    "tailwindcss": "^4.2.4",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
