{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Atlas",
  "version": "0.1.0",
  "identifier": "com.atlas.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Atlas",
        "width": 1360,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 700,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset: http://asset.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; media-src 'self' asset: http://asset.localhost data: blob:; connect-src 'self' http://127.0.0.1:* ws://127.0.0.1:* http://localhost:* ws://localhost:* https://api.deepseek.com https://api.openai.com https://api.anthropic.com; font-src 'self' data:; object-src 'none'; base-uri 'none'; frame-src 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": [
            "$AUDIO/**",
            "$VIDEO/**",
            "$DOCUMENT/**",
            "$DOWNLOAD/**"
          ],
          "deny": [
            "$HOME/.ssh/**",
            "$HOME/.gnupg/**",
            "$HOME/.aws/**",
            "$HOME/AppData/Roaming/**",
            "$HOME/AppData/Local/**"
          ]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
